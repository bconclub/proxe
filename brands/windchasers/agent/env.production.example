# Windchasers Dashboard - Production Environment Variables
# Copy this file to .env.local on your VPS and fill in the actual values

# ============================================
# Supabase Configuration (REQUIRED)
# ============================================
# Get these from: Supabase Dashboard > Settings > API
NEXT_PUBLIC_WINDCHASERS_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_WINDCHASERS_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================
# Claude API Configuration (REQUIRED)
# ============================================
# Get this from: Anthropic Console > API Keys
CLAUDE_API_KEY=sk-ant-api03-your-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514

# ============================================
# Google Calendar Integration (OPTIONAL)
# ============================================
# Only needed if you want Google Calendar booking integration
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----\n"
GOOGLE_CALENDAR_ID=your-calendar-id@gmail.com

# ============================================
# WhatsApp — Meta Cloud API (REQUIRED for WhatsApp)
# ============================================
# Get these from: developers.facebook.com → WhatsApp → API Setup
META_WHATSAPP_ACCESS_TOKEN=your-permanent-access-token
META_WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
META_WHATSAPP_WABA_ID=your-whatsapp-business-account-id
META_WHATSAPP_VERIFY_TOKEN=windchasers-proxe-verify

# Webhook URL to register in Meta Developer Console:
#   https://proxe.windchasers.in/api/agent/whatsapp/meta

# Shared API key for integrations (landing pages, etc.)
WHATSAPP_API_KEY=your-shared-api-key-here

# ============================================
# Brand & App Configuration
# ============================================
NEXT_PUBLIC_BRAND=windchasers
NEXT_PUBLIC_APP_URL=https://proxe.windchasers.in

# ============================================
# Application Configuration
# ============================================
PORT=3003
NODE_ENV=production

# Build time - automatically set during deployment
NEXT_PUBLIC_BUILD_TIME=2026-01-27T00:00:00.000Z

# ============================================
# Notes
# ============================================
# - This file should be named .env.local on the VPS
# - Never commit .env.local to git (it's in .gitignore)
# - Keep your Supabase service role key secure - it has admin access
# - The build time will be automatically updated during deployment
