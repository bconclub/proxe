# BCON Environment Variables
# Copy this to .env.local and fill in your values

# Brand
NEXT_PUBLIC_BRAND=bcon
NEXT_PUBLIC_APP_URL=https://proxe.bconclub.com

# Supabase
NEXT_PUBLIC_BCON_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_BCON_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Claude AI
CLAUDE_API_KEY=sk-ant-your-api-key
CLAUDE_MODEL=claude-sonnet-4-20250514

# Google Calendar (optional)
GOOGLE_CALENDAR_ID=your-calendar-id
GOOGLE_CALENDAR_TIMEZONE=Asia/Kolkata
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# WhatsApp - Meta Cloud API
# Get these from: https://developers.facebook.com -> WhatsApp -> API Setup
META_WHATSAPP_ACCESS_TOKEN=your-permanent-access-token
META_WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
META_WHATSAPP_WABA_ID=your-whatsapp-business-account-id
META_WHATSAPP_VERIFY_TOKEN=your-custom-verify-string

# Webhook URL to set in Meta Developer Console:
#   https://proxe.bconclub.com/api/agent/whatsapp/meta

# Instagram - Meta (Instagram API with Instagram Login)
# Get these from: https://developers.facebook.com -> PROXe app -> Instagram -> "API setup with Instagram login"
# Instagram app: PROXe-IG (app ID 734209706078170)
META_IG_ACCESS_TOKEN=your-instagram-access-token       # REQUIRED - generate via step 2 "Add account" in the IG use case
META_IG_APP_SECRET=your-instagram-app-secret           # optional - enables webhook signature check (X-Hub-Signature-256)
META_IG_BUSINESS_ACCOUNT_ID=                           # optional - leave blank, defaults to "me" (token is account-scoped)
META_IG_VERIFY_TOKEN=proxe-instagram-verify-token      # optional - already the code default; webhook verification token

# Instagram webhook URL to set in Meta (subscribe fields: messages, comments):
#   https://proxe.bconclub.com/api/agent/meta/instagram

# Legacy (only needed if using custom webhook integration)
WHATSAPP_API_KEY=your-whatsapp-api-key

# Build
NEXT_PUBLIC_BUILD_TIME=auto
