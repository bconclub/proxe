# ─────────────────────────────────────────────────────────────────────────────
# BCON PROXe — local env template   (copy to .env.local, then fill the values)
#
#   cp .env.local.example .env.local
#
# Faster than filling by hand: if this project is linked to Vercel, pull every
# value straight from the deployment instead —
#   npx vercel link        # once, pick the bcon-proxe project
#   npx vercel env pull .env.local
#
# NEXT_PUBLIC_* are exposed to the browser (safe-ish, non-secret). Everything
# else is server-only — never prefix a real secret with NEXT_PUBLIC_.
# ─────────────────────────────────────────────────────────────────────────────

# ── Brand & app identity ─────────────────────────────────────────────────────
NEXT_PUBLIC_BRAND_ID=bcon
NEXT_PUBLIC_BRAND=bcon
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000

# ── Supabase (database + auth) ───────────────────────────────────────────────
# BCON reads the BCON-prefixed pair first, falls back to the generic pair.
# For local dev you can set just one pair (use the same project for both).
NEXT_PUBLIC_BCON_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_BCON_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — full read/write, bypasses RLS. Keep secret.
SUPABASE_SERVICE_ROLE_KEY=

# ── Claude (AI engine) ───────────────────────────────────────────────────────
CLAUDE_API_KEY=
# Optional — defaults to the model set in claudeClient.ts if unset.
CLAUDE_MODEL=

# ── Meta WhatsApp (Business Management + sending) ────────────────────────────
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_WABA_ID=
META_WHATSAPP_VERIFY_TOKEN=
# Shared secret guarding the inbound WhatsApp webhook route.
WHATSAPP_API_KEY=

# ── Meta Instagram (DM channel) ──────────────────────────────────────────────
META_IG_ACCESS_TOKEN=
META_IG_APP_SECRET=
META_IG_BUSINESS_ACCOUNT_ID=
META_IG_VERIFY_TOKEN=

# ── Voice — Vapi + VoBiz SIP trunk ───────────────────────────────────────────
VAPI_PRIVATE_API_KEY=
VAPI_ASSISTANT_ID=
VAPI_OUTBOUND_PHONE_NUMBER_ID=
VAPI_SIP_URI=
VAPI_WEBHOOK_SECRET=
VOBIZ_AUTH_ID=
VOBIZ_AUTH_TOKEN=
VOBIZ_FROM_NUMBER=
# Shared secret guarding the inbound voice webhook route.
VOICE_API_KEY=

# ── Google Calendar (booking) ────────────────────────────────────────────────
GOOGLE_CALENDAR_ID=
GOOGLE_CALENDAR_TIMEZONE=Asia/Kolkata
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Paste the full key; keep the literal \n escapes (quote the whole value).
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# ── Email (Resend transactional) ─────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_FROM_NAME=

# ── Internal API auth / secrets ──────────────────────────────────────────────
ADMIN_API_KEY=
INBOUND_API_KEY=
CRON_SECRET=
WEBHOOK_SECRET=

# ── Follow-up re-engagement (RNR) — gated OFF until set ───────────────────────
# Leave BCON_RNR_TEMPLATE empty to keep the re-engagement cron inert.
BCON_RNR_TEMPLATE=
BCON_RNR_TEMPLATE_LANG=en

# ── Dev-only toggles ─────────────────────────────────────────────────────────
# BYPASS_AUTH=true skips the dashboard auth gate — LOCAL DEV ONLY, never in prod.
BYPASS_AUTH=
NEXT_PUBLIC_TEST_WHATSAPP_PHONE=

# Auto-managed (do NOT set by hand): NODE_ENV, VERCEL, NEXT_PUBLIC_BUILD_TIME
