# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# WhatsApp (Meta Cloud API)
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
WA_TEMPLATE_NAME=bcon_followup

# Telegram approval gate
# Create a bot via @BotFather, paste token here
TELEGRAM_BOT_TOKEN=
# Send /start to your bot, then use https://api.telegram.org/bot<token>/getUpdates to find your chat_id
TELEGRAM_ADMIN_CHAT_ID=
# 'approve' = messages held until approved via Telegram (default)
# 'notify'  = messages go out, admin gets a copy on Telegram
APPROVAL_MODE=approve
